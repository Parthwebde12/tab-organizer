{ "manifest_version": 3, "name": "DevFlow - Tab Organizer", "version": "3.0.0", "description": "Advanced tab organizer for developers with smart grouping, workspace management, and memory optimization", "author": "Parthwebde12", "permissions": [ "tabs", "tabGroups", "storage", "sessions", "commands" ], "host_permissions": [ "<all_urls>" ], "background": { "service_worker": "background.js" }, "action": { "default_popup": "popup.html", "default_title": "DevFlow - Tab Organizer" }, "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }, "commands": { "group-tabs": { "suggested_key": { "default": "Ctrl+Shift+G", "mac": "Command+Shift+G" }, "description": "Auto-group developer tabs by category" } }, "minimum_chrome_version": "88" }