{
  "manifest_version": 3,
  "name": "Advanced Dev Tab Organizer",
  "version": "2.0.0",
  "description": "Advanced tab organizer for developers",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sessions",
    "commands"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "group-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+G"
      },
      "description": "Auto group developer tabs"
    }
  }
}